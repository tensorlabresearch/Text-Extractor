{
  "private": true,
  "type": "module",
  "name": "text-extractor",
  "version": "0.1.0",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "PWHEADLESS=false xvfb-run --auto-servernum --server-args='-screen 0 1280x720x24' playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "vendor:transformers": "bash scripts/vendor-transformers.sh",
    "vendor:pdfjs": "bash scripts/vendor-pdfjs.sh",
    "vendor:models": "node scripts/vendor-models.mjs",
    "verify:models": "node scripts/verify-models.mjs",
    "verify:offline": "node scripts/verify-offline-package.mjs",
    "package": "node scripts/package-extension.mjs",
    "notices": "node scripts/generate-notices.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@huggingface/transformers": "^4.2.0",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.30.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.0.0",
    "onnxruntime-web": "^1.22.0",
    "pdfjs-dist": "^4.10.38",
    "vitest": "^3.0.0"
  }
}
